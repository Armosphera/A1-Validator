# Build context exclusions — keep the build small
# NB: keep the .dockerignore minimal and avoid `!pattern` exceptions
# (e.g. "exclude *.md then re-include README.md") — buildkit's cache-key
# computation has an intermittent bug where these exceptions trigger
# "not found" errors for the re-included file. Just don't exclude them.
.git
.github
.venv
venv
__pycache__
*.pyc
*.pyo
*.egg-info
build/
dist/
.pytest_cache
.mypy_cache
.ruff_cache
htmlcov/
.coverage
*.log
.DS_Store
tests/
docs/
scripts/
